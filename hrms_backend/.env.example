# ===== Server =====
NODE_ENV=development
PORT=5000

# ===== Database =====
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority

# ===== JWT =====
# JWT_SECRET is REQUIRED - use a long random string
JWT_SECRET=change_me_to_a_long_random_string
# Optional - defaults to 30d if not set
JWT_EXPIRE=30d

# ===== OTP =====
# OTP validity window in minutes (defaults to 5). The OTP email template
# automatically shows this value, so only change it here.
OTP_EXPIRY=5

# ===== Microsoft Graph Email (required for OTP emails) =====
# Azure App Registration: grant Microsoft Graph application permission Mail.Send
# and grant admin consent. EMAIL_USER must be a mailbox in that tenant.
# Used for: OTP mails, admin notifications (new signup / leave request) and
# employee notifications (registration or leave approved/rejected).
# Notifications go to every active user with role 'admin' - no extra config needed.
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret_value
EMAIL_USER=no-reply@yourdomain.com
