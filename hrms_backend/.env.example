# ===== Server =====
NODE_ENV=development
PORT=5000

# ===== Database =====
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority

# ===== JWT =====
# JWT_SECRET is REQUIRED - use a long random string
JWT_SECRET=change_me_to_a_long_random_string
# Optional - defaults to 30d if not set
JWT_EXPIRE=30d

# ===== OTP =====
# OTP validity window in minutes (defaults to 5)
OTP_EXPIRY=5

# ===== Brevo Email (required for OTP emails) =====
# Get your key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
# MUST be a real address/domain verified in your Brevo account (SPF + DKIM),
# otherwise providers like Outlook/Hotmail will junk or silently drop the mail.
BREVO_SENDER_EMAIL=no-reply@yourdomain.com
BREVO_SENDER_NAME=Lexodd Hypernova
